@{
    ViewBag.Title = "Error";
    string containerHeightClass = "";

    if (Session["User"] != null)
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_AuthLayout.cshtml";
        containerHeightClass = "vh-100";
    }
}

<style>
    .error-card {
        max-width: 480px;
        width: 100%;
        background: white;
        border-radius: 12px;
        box-shadow: 0 6px 18px rgba(21, 24, 30, 0.08);
        padding: 1.5rem;
    }

    a {
        font-size: 21px;
    }
</style>

<div class="d-flex justify-content-center align-items-center @containerHeightClass bg-light px-3 py-4">
    <div class="d-flex bg-white rounded shadow error-card">
        <div class="p-4 w-100 text-center">
            <h1 class="display-4 fw-bold mb-4">500</h1>

            <h3 class="fw-bold mb-4">Internal Server Error</h3>

            <p class="lead">
                Something went wrong while processing your request.
            </p>
            <hr />
            <p>
                Please try again later. If the problem persists, please contact the administrator.
            </p>

            <a href="@Url.Action("Index", "Home")" class="btn btn-primary mt-4">
                Return to Home
            </a>
        </div>
    </div>
</div>